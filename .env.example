# Public analytics — hardcoded in this app's source, not loaded from env.
# Documented here only for reference.
# NEXT_PUBLIC_DATAFAST_WEBSITE_ID=
# NEXT_PUBLIC_DATAFAST_DOMAIN=

# Resend — transactional email (prose-analysis flow)
RESEND_API_KEY=re_...
RESEND_SEGMENT_ID=

# Anthropic — used by /api/prose-analysis
ANTHROPIC_API_KEY=sk-ant-...

# Stripe checkout is owned by the app (app.proselab.io), not this repo.
# No Stripe keys are needed here.
